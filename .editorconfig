# EditorConfig helps maintain consistent coding styles

root = true

# All files
[*]
indent_style = space
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# JavaScript/TypeScript
[*.{js,ts,jsx,tsx,svelte}]
indent_size = 2

# Rust
[*.rs]
indent_size = 4

# YAML
[*.{yaml,yml}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# Python
[*.py]
indent_size = 4
