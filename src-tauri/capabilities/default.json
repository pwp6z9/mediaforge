{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Default capabilities for MediaForge",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/sidecar",
          "sidecar": true
        }
      ]
    },
    {
      "identifier": "shell:allow-stdin-write"
    },
    "shell:allow-open"
  ]
}
